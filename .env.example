# Production site URL — used for canonical URLs, sitemap, robots, OG, JSON-LD.
NEXT_PUBLIC_SITE_URL=https://thodasoft.com

# Shopify Storefront API (public, used for products + cart)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_api_token
SHOPIFY_STOREFRONT_API_VERSION=2024-10

# Collection handle for the homepage product grid
SHOPIFY_DEBUT_COLLECTION_HANDLE=debut-capsule

# Shopify webhook signing secret — preferred: enables HMAC verification on /api/revalidate
SHOPIFY_WEBHOOK_SECRET=your_shopify_webhook_signing_secret
# Fallback shared secret (only used if SHOPIFY_WEBHOOK_SECRET is unset)
SHOPIFY_REVALIDATE_SECRET=change_me_to_a_long_random_string

# Optional: Klaviyo (newsletter capture). Leave blank to no-op gracefully.
KLAVIYO_PRIVATE_API_KEY=
KLAVIYO_LIST_ID=

# These two are exposed to the browser for hydrogen-react's CartProvider.
# The Storefront token is *designed* to be public for client-side Storefront API calls.
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_api_token
NEXT_PUBLIC_SHOPIFY_STOREFRONT_API_VERSION=2024-10
